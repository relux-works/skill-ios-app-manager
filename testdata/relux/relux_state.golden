import Auth
import Relux

extension Auth.Business {
    @Observable
    public final class State: Relux.HybridState {
        public init() {}

        public func reduce(with action: any Relux.Action) async {
            guard let action = action as? Auth.Business.Action else { return }
            internalReduce(with: action)
        }

        public func cleanup() async {}

        private func internalReduce(with action: Auth.Business.Action) {
            switch action {}
        }
    }
}
