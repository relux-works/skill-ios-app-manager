import {{.InterfacePackageName}}
import Relux

extension {{.ModuleName}}.Business {
    public actor Flow: Relux.Flow {
        public let dispatcher: Relux.Dispatcher
        private let state: {{.ModuleName}}.Business.State

        public init(
            dispatcher: Relux.Dispatcher? = .none,
            state: {{.ModuleName}}.Business.State
        ) async {
            let defaultDispatcher = await Self.defaultDispatcher
            self.dispatcher = dispatcher ?? defaultDispatcher
            self.state = state
        }

        public func apply(_ effect: any Relux.Effect) async -> Relux.ActionResult {
            guard let effect = effect as? {{.ModuleName}}.Business.Effect else { return .success }
            return await internalApply(effect)
        }

        private func internalApply(_ effect: {{.ModuleName}}.Business.Effect) async -> Relux.ActionResult {
            switch effect {}
        }
    }
}
