import Foundation
import Observation

@MainActor
@Observable
public final class {{.ModuleName}}Store {
    public private(set) var state: {{.ModuleName}}State

    private let reducer: {{.ModuleName}}Reducer
    private let middleware: any {{.ModuleName}}MiddlewareProtocol
    private var middlewareTask: Task<Void, Never>?

    public init(
        initialState: {{.ModuleName}}State = .initial,
        reducer: {{.ModuleName}}Reducer = .init(),
        middleware: any {{.ModuleName}}MiddlewareProtocol
    ) {
        self.state = initialState
        self.reducer = reducer
        self.middleware = middleware
    }

    deinit {
        middlewareTask?.cancel()
    }

    public func dispatch(_ action: {{.ModuleName}}Action) {
        state = reducer.reduce(state: state, action: action)

        middlewareTask?.cancel()
        middlewareTask = Task { [middleware, state] in
            if let followUpAction = await middleware.handle(action: action, state: state) {
                await MainActor.run { [weak self] in
                    self?.dispatch(followUpAction)
                }
            }
        }
    }
}
