# Code generated by ios-app-manager. Edit only the custom section below.

APP_NAME := DemoApp
BUNDLE_ID := com.example.demo
TEAM_ID := ABCDE12345
MODULES_PATH := Packages
SCHEME ?= DemoApp
DESTINATION ?= platform=iOS Simulator,name=iPhone 16,OS=17.0
WORKSPACE ?= $(APP_NAME).xcworkspace
DERIVED_DATA_PATH ?= $(CURDIR)/DerivedData
TUIST_GENERATE_FLAGS ?= --no-open

PUSH_KEY_PATH := certs/AuthKey_ABC123.p8
PUSH_KEY_ID := ABC123DEF4
PUSH_ENV ?= development
PUSH_DEVICE_TOKEN ?=

.DEFAULT_GOAL := help
.PHONY: setup resetup generate build test clean deep-clean lint format validate install-tools periphery help push-token push-send

setup: ## Install Tuist dependencies and generate project files
	@tuist install
	@tuist generate $(TUIST_GENERATE_FLAGS)

resetup: ## Clean and run setup again
	@$(MAKE) clean
	@$(MAKE) setup

generate: ## Generate the Xcode project with Tuist
	@tuist generate $(TUIST_GENERATE_FLAGS)

build: ## Build the app with xcodebuild
	@xcodebuild -workspace "$(WORKSPACE)" -scheme "$(SCHEME)" -destination "$(DESTINATION)" -derivedDataPath "$(DERIVED_DATA_PATH)" build

test: ## Run tests with xcodebuild
	@xcodebuild -workspace "$(WORKSPACE)" -scheme "$(SCHEME)" -destination "$(DESTINATION)" -derivedDataPath "$(DERIVED_DATA_PATH)" test

clean: ## Clean Tuist artifacts and local DerivedData
	@tuist clean
	@rm -rf "$(DERIVED_DATA_PATH)"

deep-clean: ## Remove Xcode and SwiftPM caches for a full reset
	@rm -rf "$(DERIVED_DATA_PATH)"
	@rm -rf ~/Library/Developer/Xcode/DerivedData
	@rm -rf ~/Library/Caches/org.swift.swiftpm
	@rm -rf ~/Library/org.swift.swiftpm
	@rm -rf ~/.swiftpm
	@rm -rf ~/Library/Caches/com.apple.dt.Xcode

lint: ## Run SwiftLint
	@swiftlint

format: ## Format Swift files with SwiftFormat
	@swiftformat .

validate: lint build ## Run lint checks and build

install-tools: ## Install local tooling with Homebrew
	@brew install tuist swiftlint swiftformat periphery jq

periphery: ## Run dead-code analysis with Periphery
	@periphery scan --workspace "$(WORKSPACE)" --schemes "$(SCHEME)"

push-token: ## Print the latest APNs token from simulator logs
	@xcrun simctl spawn booted log show --last 1h --style compact 2>/dev/null | grep -Eo '[0-9a-fA-F]{64}' | tail -n 1

push-send: ## Send a test APNs notification (set PUSH_DEVICE_TOKEN)
	@if [ -z "$(PUSH_DEVICE_TOKEN)" ]; then echo "Set PUSH_DEVICE_TOKEN=<64-hex-token>"; exit 1; fi
	@if [ ! -f "$(PUSH_KEY_PATH)" ]; then echo "Missing APNs key: $(PUSH_KEY_PATH)"; exit 1; fi
	@TIME=$$(date +%s); \
	HEADER=$$(printf '{"alg":"ES256","kid":"%s"}' "$(PUSH_KEY_ID)" | openssl base64 -e -A | tr '+/' '-_' | tr -d '='); \
	CLAIMS=$$(printf '{"iss":"%s","iat":%s}' "$(TEAM_ID)" "$$TIME" | openssl base64 -e -A | tr '+/' '-_' | tr -d '='); \
	SIGNATURE=$$(printf "%s.%s" "$$HEADER" "$$CLAIMS" | openssl dgst -binary -sha256 -sign "$(PUSH_KEY_PATH)" | openssl base64 -e -A | tr '+/' '-_' | tr -d '='); \
	JWT="$$HEADER.$$CLAIMS.$$SIGNATURE"; \
	ENDPOINT="https://api.development.push.apple.com"; \
	if [ "$(PUSH_ENV)" = "production" ]; then ENDPOINT="https://api.push.apple.com"; fi; \
	curl --fail-with-body --http2 \
		--header "authorization: bearer $$JWT" \
		--header "apns-topic: $(BUNDLE_ID)" \
		--header "apns-push-type: alert" \
		--header "content-type: application/json" \
		--data "{\"aps\":{\"alert\":\"Test push from $(APP_NAME)\",\"sound\":\"default\"}}" \
		"$$ENDPOINT/3/device/$(PUSH_DEVICE_TOKEN)"

help: ## Show available Make targets
	@awk 'BEGIN {FS = ":.*##"; printf "\nAvailable targets:\n"} /^[a-zA-Z0-9_.-]+:.*##/ {printf "  %-20s %s\n", $$1, $$2}' $(MAKEFILE_LIST)

