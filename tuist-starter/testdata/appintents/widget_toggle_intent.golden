import AppIntents
import WidgetKit

public struct DemoAppWidgetToggleIntent: AppIntent {
    public static var title: LocalizedStringResource = "Toggle Widget"
    public static var description: IntentDescription = "Toggles shared widget state"

    public init() {}

    public func perform() async throws -> some IntentResult {
        let defaults = UserDefaults(suiteName: "group.com.demo.shared")
        let current = defaults?.bool(forKey: "widgetToggle") ?? false
        defaults?.set(!current, forKey: "widgetToggle")

        WidgetCenter.shared.reloadAllTimelines()

        return .result()
    }
}
