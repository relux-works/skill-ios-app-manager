import WidgetKit
import Foundation

public struct DemoAppTimelineProvider: TimelineProvider {
    private let defaults = UserDefaults(suiteName: "group.com.demo.shared")

    public init() {}

    public func placeholder(in context: Context) -> DemoAppTimelineEntry {
        DemoAppTimelineEntry(date: Date(), title: "DemoApp", isToggled: false)
    }

    public func getSnapshot(in context: Context, completion: @escaping (DemoAppTimelineEntry) -> Void) {
        let toggled = defaults?.bool(forKey: "widgetToggle") ?? false
        completion(DemoAppTimelineEntry(date: Date(), title: "DemoApp", isToggled: toggled))
    }

    public func getTimeline(in context: Context, completion: @escaping (Timeline<DemoAppTimelineEntry>) -> Void) {
        let toggled = defaults?.bool(forKey: "widgetToggle") ?? false
        let entry = DemoAppTimelineEntry(date: Date(), title: "DemoApp", isToggled: toggled)
        completion(Timeline(entries: [entry], policy: .after(Date().addingTimeInterval(60 * 15))))
    }
}
