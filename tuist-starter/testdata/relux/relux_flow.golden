import Auth
import Relux

extension Auth.Business {
    public actor Flow: Relux.Flow {
        public let dispatcher: Relux.Dispatcher
        private let state: Auth.Business.State

        public init(
            dispatcher: Relux.Dispatcher? = .none,
            state: Auth.Business.State
        ) async {
            let defaultDispatcher = await Self.defaultDispatcher
            self.dispatcher = dispatcher ?? defaultDispatcher
            self.state = state
        }

        public func apply(_ effect: any Relux.Effect) async -> Relux.ActionResult {
            guard let effect = effect as? Auth.Business.Effect else { return .success }
            return await internalApply(effect)
        }

        private func internalApply(_ effect: Auth.Business.Effect) async -> Relux.ActionResult {
            switch effect {}
        }
    }
}
