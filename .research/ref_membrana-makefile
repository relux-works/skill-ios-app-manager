## Обновление всех репозиториев зависимостей
checkout:
	@echo "Переход в директорию packages..."
	@cd .. && cd packages && \
	for repo in $(REPOS); do \
		echo "Обработка репозитория $$repo..."; \
		if [ -d "$$repo" ]; then \
			echo "Репозиторий $$repo найден, обновляем..."; \
			(cd "$$repo" && \
			git checkout main && \
			git pull origin main && \
			cd ..) || (echo "Ошибка при обработке репозитория $$repo!" && exit 1); \
		else \
			echo "Репозиторий $$repo не найден, пропускаем..."; \
		fi; \
	done && \
	echo "Все репозитории успешно обновлены."

## Настройка шаблонов Xcode
setup.templates:
	@echo "Переход в директорию packages..."
	@cd .. && cd packages || (echo "Директория packages не найдена!" && exit 1)

	@echo "Клонирование ios-infrastructure..."
	@if [ ! -d "ios-infrastructure" ]; then \
		git clone git@gitlab.services.mts.ru:fc-telecom/mobile/ios/packages/ios-infrastructure.git || (echo "Ошибка при клонировании ios-infrastructure!" && exit 1); \
	else \
		echo "Репозиторий ios-infrastructure уже существует, пропускаем клонирование..."; \
	fi

	@echo "Переход в директорию ios-infrastructure/xcode..."
	@cd ios-infrastructure && \
	if [ -d "xcode" ]; then \
		cd xcode && \
		echo "Копирование шаблонов Xcode..."; \
		cp -R Templates ~/Library/Developer/Xcode || (echo "Ошибка при копировании шаблонов!" && exit 1); \
	else \
		echo "Директория xcode не найдена в ios-infrastructure!"; \
		exit 1; \
	fi

	@echo "Шаблоны Xcode успешно настроены."


## Очистка кэшей и временных файлов
clean:
	@echo "Очистка кэшей и временных файлов..."
	@rm -rf ~/Library/org.swift.swiftpm
	@rm -rf ~/Library/Caches/org.swift.swiftpm
	@rm -rf ~/Library/Developer/Xcode/DerivedData
	@rm -rf DerivedData
	@echo "Очистка завершена."

lint:
	swiftlint lint --quiet

check_localization:
	@cd scripts && \
	cd checkLocalization && \
	swift run checkLocalization --sources=../../Application/Sources --localizationResources=../../Application/Resources/Localization --mode=console --ignore="NS*,l10n.app.owner.*" --validThreshold=2
