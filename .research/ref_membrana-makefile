## Генерация проекта
xcgen:
	$(MAKE) kill_xcode
	$(MAKE) generate_manifest
	$(MAKE) generate_project
	$(MAKE) install_pods

# Завершение Xcode
kill_xcode:
	@echo "Завершение Xcode..."
	@-pkill Xcode 2>/dev/null || true

# Генерация манифеста
generate_manifest:
	@echo "Генерация манифеста..."
	@cd scripts/prepareProjManifest && \
	swift run prepareProjManifest -- \
		template:../../proj_manifest_template.xcodeprojless \
		config:../../proj_config_fc.xcodeprojless \
		destination:../../proj_manifest.xcodeprojless
	@cd ../..

# Генерация проекта
generate_project:
	@echo "Создание Xcode-проекта..."
	@xcodegen generate --spec proj_manifest.xcodeprojless

## Установка зависимостей
install_pods:
	@echo "Установка CocoaPods..."
	@pod install || pod install --repo-update

# Список репозиториев для checkout
