SHELL := /bin/bash

## Команда для инициализации проекта, выполняйте всегда перед первым стартом!
init:
	/bin/bash -c "$$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	# Добавление Homebrew в PATH (если не добавлен)
	@if ! echo "$$PATH" | grep -q "/opt/homebrew/bin"; then \
	echo 'export PATH="/opt/homebrew/bin:$$PATH"' >> ~/.zshrc; \
	echo "Homebrew добавлен в PATH (файл ~/.zshrc)."; \
	else \
	echo "Homebrew уже добавлен в PATH."; \
	fi

	# Применение изменений
	@source ~/.zshrc
	@echo "Установка завершена. Проверьте Homebrew: brew --version"
	brew install git
	brew install xcodegen
	brew install swiftlint
	brew install xcode-build-server
	brew install xcbeautify
	brew install swiftformat
	$(MAKE) install.creds
	$(MAKE) setup
	$(MAKE) xcgen

# Добавит сертификаты и профайлы в связку ключей
install.creds:
	eval `ssh-agent -s`
	ssh-add ~/.ssh/id_rsa

